# ============================================================
# SOUNDWAVE — Backend Environment Variables
# Copy this to .env and fill in your actual values.
# NEVER commit .env to git.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Supabase — get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Storage — using Supabase Storage (free, no card needed)
# Bucket name you create in Supabase → Storage → New bucket
STORAGE_BUCKET=audio

# Audio upload limits
MAX_UPLOAD_SIZE_MB=200
ALLOWED_AUDIO_FORMATS=audio/wav,audio/flac,audio/mpeg,audio/aiff,audio/x-aiff

# App
FRONTEND_URL=http://localhost:8081
